# Stripe (required for checkout)
# Get your key at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Optional: base URL for success/cancel redirects (defaults to request origin)
# NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Canonical URL for Open Graph / Twitter link previews when shared (set in production)
NEXT_PUBLIC_SITE_URL=https://www.arya.clothing

# Waitlist (Resend) — you get an email for each signup
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_...
# Where to receive waitlist signup notifications (default: hello@arya.clothing)
WAITLIST_NOTIFY_EMAIL=hello@arya.clothing
# Optional: custom "from" (must be a verified domain in Resend for production)
# RESEND_FROM=Arya <notify@yourdomain.com>
